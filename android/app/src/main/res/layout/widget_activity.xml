<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_background"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:paddingStart="15dp"
    android:paddingTop="13dp"
    android:paddingEnd="15dp"
    android:paddingBottom="13dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@android:drawable/ic_popup_sync"
            android:tint="@color/widget_icon" />

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/widget_activity_title"
            android:textColor="@color/widget_title"
            android:textSize="12sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:contentDescription="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_primary_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_activity_no_session"
        android:textColor="@color/widget_primary"
        android:textSize="21sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:contentDescription="@null" />

    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="7dp"
        android:text="@string/widget_activity_total_sessions"
        android:textColor="@color/widget_footer"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@android:drawable/ic_menu_recent_history"
            android:tint="@color/widget_icon" />

        <ProgressBar
            android:id="@+id/widget_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="6dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_progress_horizontal" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="@color/widget_divider"
        android:text="" />

    <TextView
        android:id="@+id/widget_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/widget_hint_open"
        android:textColor="@color/widget_hint"
        android:textSize="10sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:contentDescription="@null" />
</LinearLayout>
