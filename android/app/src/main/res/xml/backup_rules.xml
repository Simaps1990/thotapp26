<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclure totalement les fichiers applicatifs (données THOT). -->
    <exclude domain="file" />
    <!-- Préférences utilisateur non sensibles (thème, langue, réglages). -->
    <include domain="sharedpref" path="." />
</full-backup-content>