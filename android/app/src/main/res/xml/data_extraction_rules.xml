<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclure totalement les fichiers applicatifs (données THOT). -->
        <exclude domain="file" />
        <!-- Préférences utilisateur non sensibles (thème, langue, réglages). -->
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Cohérence avec cloud backup : pas de transfert auto des données THOT. -->
        <exclude domain="file" />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>